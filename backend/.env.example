# Kopernik Harvest — Backend Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

APP_NAME=Kopernik Harvest

# JWT signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET

ALGORITHM=HS256

# Login session duration in minutes (480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# SQLite (local / Render free tier)
DATABASE_URL=sqlite:///./kopernik_harvest.db

# Set False in production
DEBUG=False

# Comma-separated list of allowed frontend origins
# Local development:
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Production (replace with your actual Vercel URL):
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Email notifications — set EMAIL_ENABLED=true and fill SMTP_* vars to activate
# For Gmail: use an App Password (Account > Security > 2FA > App passwords)
# For M365: SMTP_HOST=smtp.office365.com, SMTP_PORT=587, use your M365 password
# For SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587, SMTP_USERNAME=apikey, SMTP_PASSWORD=<API key>
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Kopernik Harvest

# Frontend base URL — used in email deep-links (no trailing slash)
APP_BASE_URL=https://your-app.vercel.app
